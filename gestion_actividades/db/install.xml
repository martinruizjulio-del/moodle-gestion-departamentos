<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/gestion_actividades/db" VERSION="2026071001" COMMENT="Gestion_actividades install schema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_ga_activities" COMMENT="Managed merit activity definitions">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="activitykey" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="teacherid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="places" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="20"/>
        <FIELD NAME="idfield" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="email"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="activitykey" UNIQUE="false" FIELDS="activitykey"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_ga_imports" COMMENT="CSV imports for merit activities">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="activityid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="filename" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="notes" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="activityid" UNIQUE="false" FIELDS="activityid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_ga_candidates" COMMENT="Imported candidates and ranking status">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="activityid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="importid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="identifier" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="firstname" TYPE="char" LENGTH="100" NOTNULL="false"/>
        <FIELD NAME="lastname" TYPE="char" LENGTH="100" NOTNULL="false"/>
        <FIELD NAME="email" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="username" TYPE="char" LENGTH="100" NOTNULL="false"/>
        <FIELD NAME="idnumber" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="grade" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="false"/>
        <FIELD NAME="rank" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="candidate"/>
        <FIELD NAME="reason" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="activityid" UNIQUE="false" FIELDS="activityid"/>
        <INDEX NAME="importid" UNIQUE="false" FIELDS="importid"/>
        <INDEX NAME="userid" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="status" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_ga_participants" COMMENT="Selected participants and group membership created by the plugin">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="activityid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="candidateid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="grade" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="false"/>
        <FIELD NAME="rank" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="groupid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="selected"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="activityid" UNIQUE="false" FIELDS="activityid"/>
        <INDEX NAME="userid" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="groupid" UNIQUE="false" FIELDS="groupid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_ga_completions" COMMENT="Completed or certified historical records used for exclusion">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="activitykey" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="activityid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="status" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="completed"/>
        <FIELD NAME="source" TYPE="char" LENGTH="50" NOTNULL="false"/>
        <FIELD NAME="timecompleted" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="activitykeyuserid" UNIQUE="false" FIELDS="activitykey, userid"/>
        <INDEX NAME="activityid" UNIQUE="false" FIELDS="activityid"/>
      </INDEXES>
    </TABLE>


    <TABLE NAME="local_ga_grades" COMMENT="Transcript grade history imported by academic year">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="activityid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="activitykey" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="academicyear" TYPE="char" LENGTH="30" NOTNULL="true"/>
        <FIELD NAME="grade" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="false"/>
        <FIELD NAME="importid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="usermodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="activitykeyuseracademic" UNIQUE="true" FIELDS="activitykey, userid, academicyear"/>
        <INDEX NAME="activityid" UNIQUE="false" FIELDS="activityid"/>
        <INDEX NAME="userid" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="academicyear" UNIQUE="false" FIELDS="academicyear"/>
      </INDEXES>
    </TABLE>
  
    <TABLE NAME="local_ga_workshops" COMMENT="Base workshops managed by Gestion_actividades">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="code" TYPE="char" LENGTH="50" NOTNULL="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="allowrepeat" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="hours" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
        <FIELD NAME="sectionnum" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="coursecode" UNIQUE="true" FIELDS="courseid, code"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ga_workshop_editions" COMMENT="Specific workshop editions or offerings">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="workshopid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="activityid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="editioncode" TYPE="char" LENGTH="80" NOTNULL="true"/>
        <FIELD NAME="sessiondate" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="enrolenddate" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="places" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="groupid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="attendancecmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="certificatecmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="requiredcmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="requiredmodname" TYPE="char" LENGTH="20" NOTNULL="false"/>
        <FIELD NAME="activitycreationtype" TYPE="char" LENGTH="20" NOTNULL="false"/>
        <FIELD NAME="tasknumericgrade" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
        <FIELD NAME="quizgradingmode" TYPE="char" LENGTH="20" NOTNULL="false"/>
        <FIELD NAME="archived" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timearchived" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="status" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="open"/>
        <FIELD NAME="completed" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecompleted" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="completedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="workshopid" UNIQUE="false" FIELDS="workshopid"/>
        <INDEX NAME="activityid" UNIQUE="false" FIELDS="activityid"/>
        <INDEX NAME="groupid" UNIQUE="false" FIELDS="groupid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ga_edition_teachers" COMMENT="Teachers assigned to workshop editions">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="editionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="editionuserid" UNIQUE="true" FIELDS="editionid, userid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ga_edition_enrolments" COMMENT="Students enrolled in specific workshop editions">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="editionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="workshopid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="groupid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="status" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="enrolled"/>
        <FIELD NAME="reason" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="editionuser" UNIQUE="true" FIELDS="editionid, userid"/>
        <INDEX NAME="workshopuser" UNIQUE="false" FIELDS="workshopid, userid"/>
      </INDEXES>
    </TABLE>

  
    <TABLE NAME="local_ga_hour_history" COMMENT="Completed Type A workshop hours history">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="workshopid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="editionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="workshopcode" TYPE="char" LENGTH="40" NOTNULL="false"/>
        <FIELD NAME="workshopname" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="editionname" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="hours" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="certificatecmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="certificatestatus" TYPE="char" LENGTH="40" NOTNULL="false" DEFAULT="pending"/>
        <FIELD NAME="timecompleted" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="useridx" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="editionuseridx" UNIQUE="true" FIELDS="editionid, userid"/>
      </INDEXES>
    </TABLE>

  
    <TABLE NAME="local_ga_authorized" COMMENT="Authorized plugin managers">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="addedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_uix" UNIQUE="true" FIELDS="userid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ga_materials" COMMENT="Workshop materials">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="workshopid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="editionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="url" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="visible" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="fileitemid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="workshopid_idx" UNIQUE="false" FIELDS="workshopid"/>
        <INDEX NAME="editionid_idx" UNIQUE="false" FIELDS="editionid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_ga_certificates" COMMENT="Generated workshop certificates">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="workshopid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="editionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="certcode" TYPE="char" LENGTH="80" NOTNULL="true"/>
        <FIELD NAME="filename" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="generated"/>
        <FIELD NAME="timeissued" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="editionuser" UNIQUE="true" FIELDS="editionid, userid"/>
        <INDEX NAME="userid" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="courseid" UNIQUE="false" FIELDS="courseid"/>
      </INDEXES>
    </TABLE>


  </TABLES>
</XMLDB>
